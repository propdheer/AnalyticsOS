# AnalyticsOS environment configuration

ANALYTICSOS_ENVIRONMENT=development
ANALYTICSOS_API_HOST=127.0.0.1
ANALYTICSOS_API_PORT=8000

# Runtime path options.
# Pick different values per machine.
#
# Office laptop example:
# ANALYTICSOS_DATA_DIR=C:\Users\Dheer.Madhusudan\OneDrive - Sundrop Brands Limited\AnalyticsOS-runtime\data
# ANALYTICSOS_KNOWLEDGE_DIR=C:\Users\Dheer.Madhusudan\OneDrive - Sundrop Brands Limited\AnalyticsOS-runtime\knowledge
#
# Personal laptop example:
# ANALYTICSOS_DATA_DIR=%LOCALAPPDATA%\AnalyticsOS\data
# ANALYTICSOS_KNOWLEDGE_DIR=%LOCALAPPDATA%\AnalyticsOS\knowledge
#
# If omitted, AnalyticsOS defaults to repo-relative ../data and ../knowledge.
ANALYTICSOS_DATA_DIR=../data
ANALYTICSOS_KNOWLEDGE_DIR=../knowledge

# Optional snapshot sync folder
ANALYTICSOS_SYNC_DIR=

ANALYTICSOS_OLLAMA_BASE_URL=http://127.0.0.1:11434
ANALYTICSOS_OLLAMA_DEFAULT_MODEL=llama3.1

ANALYTICSOS_OBSIDIAN_VAULT_PATH=

ANALYTICSOS_ANYTHINGLLM_BASE_URL=
ANALYTICSOS_ANYTHINGLLM_API_KEY=
ANALYTICSOS_ANYTHINGLLM_WORKSPACE_SLUG=
